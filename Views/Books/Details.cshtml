@model SmallShopSystem.Models.Book

@{
    ViewData["Title"] = "图书详情";
    var isCustomer = User.IsInRole("Customer") || !(User.IsInRole("Admin") || User.IsInRole("Warehouse") || User.IsInRole("Support"));
}

<h1>图书详情</h1>

<div>
    <h4>图书信息</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Title)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ISBN)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ISBN)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Price)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Price)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Stock)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Stock)
        </dd>
        <dt class = "col-sm-2">
            分类
        </dt>
        <dd class = "col-sm-10">
            @Model.Category?.Name
        </dd>
        <dt class = "col-sm-2">
            出版商
        </dt>
        <dd class = "col-sm-10">
            @Model.Publisher?.Name
        </dd>
    </dl>
</div>
<div>
    @if (!isCustomer)
    {
        <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a>
    }
    else
    {
        <a asp-action="Order" asp-route-id="@Model?.Id" class="btn btn-primary">下单</a>
    }
    <a asp-action="Index">Back to List</a>
</div>
