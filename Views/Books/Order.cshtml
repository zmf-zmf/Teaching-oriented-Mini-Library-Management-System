@model SmallShopSystem.Models.Book

@{
    ViewData["Title"] = "下单";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h1 class="h4 mb-3">图书下单</h1>
                <p class="text-muted">确认图书后输入数量即可下单。</p>

                <dl class="row">
                    <dt class="col-sm-3">书名</dt>
                    <dd class="col-sm-9">@Model.Title</dd>

                    <dt class="col-sm-3">分类</dt>
                    <dd class="col-sm-9">@Model.Category?.Name</dd>

                    <dt class="col-sm-3">出版社</dt>
                    <dd class="col-sm-9">@Model.Publisher?.Name</dd>

                    <dt class="col-sm-3">单价</dt>
                    <dd class="col-sm-9">￥@Model.Price</dd>
                </dl>

                <form asp-action="Order" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label for="quantity" class="form-label">购买数量</label>
                        <input id="quantity" name="quantity" type="number" class="form-control" min="1" value="1" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">确认下单</button>
                </form>
            </div>
        </div>
    </div>
</div>
