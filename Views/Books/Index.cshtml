@model IEnumerable<SmallShopSystem.Models.Book>

@{
    ViewData["Title"] = "图书浏览";
    var isCustomer = User.IsInRole("Customer") || !(User.IsInRole("Admin") || User.IsInRole("Warehouse") || User.IsInRole("Support"));
}

<div class="page-header mb-4">
    <div>
        <h1 class="h3 mb-1">图书浏览</h1>
        <p class="text-muted mb-0">这里展示当前可查看的图书信息。</p>
    </div>
    @if (!isCustomer)
    {
        <div>
            <a asp-action="Create" class="btn btn-primary">新增图书</a>
        </div>
    }
</div>

@if (isCustomer)
{
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@item.Title</h5>
                        <p class="card-text text-muted mb-1">分类：@item.Category?.Name</p>
                        <p class="card-text text-muted mb-1">出版社：@item.Publisher?.Name</p>
                        <p class="card-text mb-1">价格：￥@item.Price</p>
                        <p class="card-text mb-3">库存：@item.Stock</p>
                        <div class="mt-auto d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary w-50">详情</a>
                            <a asp-action="Order" asp-route-id="@item.Id" class="btn btn-primary w-50">下单</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.Title)</th>
                <th>@Html.DisplayNameFor(model => model.ISBN)</th>
                <th>@Html.DisplayNameFor(model => model.Price)</th>
                <th>@Html.DisplayNameFor(model => model.Stock)</th>
                <th>分类</th>
                <th>出版商</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Title)</td>
                <td>@Html.DisplayFor(modelItem => item.ISBN)</td>
                <td>@Html.DisplayFor(modelItem => item.Price)</td>
                <td>@Html.DisplayFor(modelItem => item.Stock)</td>
                <td>@item.Category?.Name</td>
                <td>@item.Publisher?.Name</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
