@{
    ViewData["Title"] = "首页";
    var isAdmin = User.IsInRole("Admin");
    var isWarehouse = User.IsInRole("Warehouse");
    var isSupport = User.IsInRole("Support");
    var isCustomer = User.IsInRole("Customer") || !(isAdmin || isWarehouse || isSupport);
}

@if (User?.Identity?.IsAuthenticated ?? false)
{
        <div class="text-center py-4 border-bottom mb-4">
        <h1 class="display-5 fw-bold">✨ 欢迎进入 SmallShop</h1>
        <p class="lead text-muted mb-0">当前登录后看到的是与你角色相关的工作台</p>
    </div>

    @if (isAdmin)
    {
        <div class="row g-4">
            <div class="col-md-3">
                <div class="card h-100 shadow-sm text-center">
                    <div class="card-body">
                        <div class="display-4 mb-2">📚</div>
                        <h5>图书管理</h5>
                        <p class="text-muted small">图书、价格、库存。</p>
                        <a asp-controller="Books" asp-action="Index" class="btn btn-dark w-100">进入</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 shadow-sm text-center">
                    <div class="card-body">
                        <div class="display-4 mb-2">🗂️</div>
                        <h5>分类管理</h5>
                        <p class="text-muted small">维护图书分类。</p>
                        <a asp-controller="Categories" asp-action="Index" class="btn btn-dark w-100">进入</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 shadow-sm text-center">
                    <div class="card-body">
                        <div class="display-4 mb-2">🏢</div>
                        <h5>出版商管理</h5>
                        <p class="text-muted small">维护出版商信息。</p>
                        <a asp-controller="Publishers" asp-action="Index" class="btn btn-dark w-100">进入</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 shadow-sm text-center">
                    <div class="card-body">
                        <div class="display-4 mb-2">🚚</div>
                        <h5>订单与发货</h5>
                        <p class="text-muted small">查看、处理、发货。</p>
                        <a asp-controller="Orders" asp-action="Index" class="btn btn-dark w-100">进入</a>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (isWarehouse)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card shadow-sm text-center">
                    <div class="card-body py-4">
                        <div class="text-muted small text-uppercase">待发货订单</div>
                        <div class="display-6 fw-bold text-warning">@ViewBag.PendingOrders</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm text-center">
                    <div class="card-body py-4">
                        <div class="text-muted small text-uppercase">库存预警</div>
                        <div class="display-6 fw-bold text-danger">@ViewBag.LowStockCount</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm text-center">
                    <div class="card-body py-4">
                        <div class="text-muted small text-uppercase">工作入口</div>
                        <a asp-controller="Orders" asp-action="Index" class="btn btn-dark mt-2">进入订单中心</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <strong>最近待发货订单</strong>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>订单号</th>
                                <th>图书</th>
                                <th>数量</th>
                                <th>客户</th>
                                <th>下单时间</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in ((IEnumerable<SmallShopSystem.Models.Order>?)ViewBag.RecentPendingOrders) ?? Array.Empty<SmallShopSystem.Models.Order>())
                            {
                                <tr>
                                    <td>#@order.Id</td>
                                    <td>@order.Book?.Title</td>
                                    <td>@order.Quantity</td>
                                    <td>@order.Customer?.Name</td>
                                    <td>@order.OrderDate.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>
                                        <a asp-controller="Orders" asp-action="Edit" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">处理</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else if (isSupport)
    {
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card h-100 shadow-sm text-center">
                    <div class="card-body">
                        <div class="display-4 mb-2">👥</div>
                        <h4>客户管理</h4>
                        <p class="text-muted small">维护客户基础信息。</p>
                        <a asp-controller="Customers" asp-action="Index" class="btn btn-dark w-100">进入客户管理</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100 shadow-sm text-center">
                    <div class="card-body">
                        <div class="display-4 mb-2">🚚</div>
                        <h4>订单查询</h4>
                        <p class="text-muted small">查看订单状态，不显示仓库操作。</p>
                        <a asp-controller="Orders" asp-action="Index" class="btn btn-dark w-100">进入订单中心</a>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (isCustomer)
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="h4 mb-1">🛍️ 客户首页</h2>
                <p class="text-muted mb-0">这里展示部分图书，你可以直接浏览并下单。</p>
            </div>
            <a asp-controller="Books" asp-action="Index" class="btn btn-outline-dark">进入完整图书列表</a>
        </div>

        <div class="row g-4">
            @foreach (var book in ((IEnumerable<SmallShopSystem.Models.Book>?)ViewBag.FeaturedBooks) ?? Array.Empty<SmallShopSystem.Models.Book>())
            {
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@book.Title</h5>
                            <p class="card-text text-muted mb-1">分类：@book.Category?.Name</p>
                            <p class="card-text text-muted mb-1">出版社：@book.Publisher?.Name</p>
                            <p class="card-text mb-3">价格：￥@book.Price</p>
                            <div class="mt-auto d-flex gap-2">
                                <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id" class="btn btn-outline-secondary w-50">详情</a>
                                <a asp-controller="Books" asp-action="Order" asp-route-id="@book.Id" class="btn btn-primary w-50">下单</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}
else
{
    <div class="text-center py-5 border-bottom mb-5">
                        <h1 class="display-4 fw-bold text-uppercase" style="letter-spacing: 5px;">📘 SmallShop</h1>
        <p class="lead text-muted">登录后进入不同角色的专属工作台</p>
    </div>

    <div class="row g-4 justify-content-center">
        <div class="col-md-5">
            <div class="card h-100 shadow-sm text-center">
                <div class="card-body p-4">
                    <div class="display-4 mb-3">🔐</div>
                    <h4 class="card-title fw-bold">登录</h4>
                    <p class="card-text text-muted small">进入对应角色界面。</p>
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-dark w-100 py-2">去登录</a>
                </div>
            </div>
        </div>
        <div class="col-md-5">
            <div class="card h-100 shadow-sm text-center">
                <div class="card-body p-4">
                    <div class="display-4 mb-3">📝</div>
                    <h4 class="card-title fw-bold">注册</h4>
                    <p class="card-text text-muted small">注册后自动成为客户。</p>
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-dark w-100 py-2">去注册</a>
                </div>
            </div>
        </div>
    </div>
}
