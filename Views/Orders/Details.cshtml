@model SmallShopSystem.Models.Order

@{
    ViewData["Title"] = "订单详情";
}

<h1>订单详情</h1>

<div>
    <h4>Order</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.OrderDate)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.OrderDate)
        </dd>
    <dt class = "col-sm-2">图书</dt>
    <dd class = "col-sm-10">@Model.Book?.Title</dd>

    <dt class = "col-sm-2">数量</dt>
    <dd class = "col-sm-10">@Model.Quantity</dd>

    <dt class = "col-sm-2">
        @Html.DisplayNameFor(model => model.Status)
    </dt>
    <dd class = "col-sm-10">
        @Html.DisplayFor(model => model.Status)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Customer)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Customer.Id)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
