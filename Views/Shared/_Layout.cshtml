<!DOCTYPE html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmallShopSystem</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootswatch/5.3.2/lux/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SmallShopSystem.styles.css" asp-append-version="true" />
    <style>
        /* 增加一点自定义样式，让页面更有质感 */
        body { background-color: #f8f9fa; }
        .navbar { text-transform: uppercase; letter-spacing: 1px; }
        .main-container {
            background: white;
            border-radius: 8px;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.05);
            margin-top: 2rem;
            padding: 2rem;
        }
        footer { margin-top: 3rem; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">📚 SmallShop</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">首页</a>
                        </li>

                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            var isAdmin = User.IsInRole("Admin");
                            var isWarehouse = User.IsInRole("Warehouse");
                            var isSupport = User.IsInRole("Support");
                            var isCustomer = User.IsInRole("Customer");

                            @if (isAdmin || isCustomer)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Books" asp-action="Index">图书信息</a>
                                </li>
                            }

                            @if (isAdmin)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Categories" asp-action="Index">分类</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Publishers" asp-action="Index">出版商</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Customers" asp-action="Index">客户管理</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link fw-bold text-info" asp-area="" asp-controller="Orders" asp-action="Index">订单/发货</a>
                                </li>
                            }
                            else if (isWarehouse)
                            {
                                <li class="nav-item">
                                    <a class="nav-link fw-bold text-info" asp-area="" asp-controller="Orders" asp-action="Index">订单/发货</a>
                                </li>
                            }
                            else if (isSupport)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Customers" asp-action="Index">客户管理</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link fw-bold text-info" asp-area="" asp-controller="Orders" asp-action="Index">订单/发货</a>
                                </li>
                            }
                        }
                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3 main-container">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white py-3">
        <div class="container">
            &copy; 2026 - SmallShopSystem - 管理后台
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>