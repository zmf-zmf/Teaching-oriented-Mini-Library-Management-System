<!DOCTYPE html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmallShopSystem</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootswatch/5.3.2/lux/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SmallShopSystem.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-uppercase d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index"><span>📘</span><span>SmallShop</span></a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between align-items-lg-center">
                    <ul class="navbar-nav flex-grow-1 align-items-lg-center gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link px-lg-3" asp-area="" asp-controller="Home" asp-action="Index">🏠 首页</a>
                        </li>

                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            var isAdmin = User.IsInRole("Admin");
                            var isWarehouse = User.IsInRole("Warehouse");
                            var isSupport = User.IsInRole("Support");
                            var isCustomer = User.IsInRole("Customer") || !(isAdmin || isWarehouse || isSupport);

                            @if (isAdmin || isCustomer)
                            {
                                <li class="nav-item">
                                    <a class="nav-link px-lg-3" asp-area="" asp-controller="Books" asp-action="Index">📚 图书</a>
                                </li>
                            }

                            @if (isAdmin)
                            {
                                <li class="nav-item">
                                    <a class="nav-link px-lg-3" asp-area="" asp-controller="Categories" asp-action="Index">🗂️ 分类</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link px-lg-3" asp-area="" asp-controller="Publishers" asp-action="Index">🏢 出版商</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link px-lg-3" asp-area="" asp-controller="Customers" asp-action="Index">👥 客户</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link px-lg-3 fw-semibold text-info" asp-area="" asp-controller="Orders" asp-action="Index">🚚 订单/发货</a>
                                </li>
                            }
                            else if (isWarehouse)
                            {
                                <li class="nav-item">
                                    <a class="nav-link px-lg-3 fw-semibold text-info" asp-area="" asp-controller="Orders" asp-action="Index">🚚 订单/发货</a>
                                </li>
                            }
                            else if (isSupport)
                            {
                                <li class="nav-item">
                                    <a class="nav-link px-lg-3" asp-area="" asp-controller="Customers" asp-action="Index">👥 客户</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link px-lg-3 fw-semibold text-info" asp-area="" asp-controller="Orders" asp-action="Index">🚚 订单/发货</a>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="nav-link px-lg-3" asp-controller="Profile" asp-action="Index">👤 个人中心</a>
                            </li>
                        }
                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="page-shell py-4 py-lg-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer bg-white py-3 shadow-sm mt-auto">
        <div class="container">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 text-muted small">
                <span>© 2026 - SmallShopSystem</span>
                <span>📚 书店管理系统 · B/S 架构</span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>